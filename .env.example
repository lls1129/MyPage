# Copy this file to `.env.local` and fill in real values.
# Vercel: paste the same values into Project → Settings → Environment Variables.

# Supabase project URL (Project Settings → API → Project URL).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase public anon key (Project Settings → API → anon public).
# Safe to expose; row-level security policies enforce real access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email allowed to sign into /admin. Server-only, never exposed to the browser.
# Magic-link sign-in will refuse any other address.
ADMIN_EMAIL=
